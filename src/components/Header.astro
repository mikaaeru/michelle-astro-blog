---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, '');
const activeStyle = "background:var(--pink-neon); color:white; box-shadow: inset 3px 3px 0 rgba(255,255,255,0.2), inset -3px -3px 0 rgba(0,0,0,0.4), 3px 5px 0 #000, 0 0 15px var(--pink-neon);";
---

<header>
    <div class="nav-container">
        <div class="logo">Michelle's<a href="/admin/analytics" style="color: var(--text-main); text-decoration: none; cursor: pointer;"> SHIT</a></div>
        
        <button class="menu-toggle" id="menuToggle" onclick="toggleMenu()" aria-label="Toggle Menu">
            <span class="burger-line"></span>
            <span class="burger-line"></span>
            <span class="burger-line"></span>
        </button>

        <nav class="nav-links" id="navLinks">
            <a href="/" class="mc-btn" style={currentPath === '' ? activeStyle : ''}>Home</a>
            <a href="/blog" class="mc-btn" style={currentPath.startsWith('/blog') ? activeStyle : ''}>Blogs</a>
            <a href="/about" class="mc-btn" style={currentPath === '/about' ? activeStyle : ''}>About</a>
            <a href="/onlyfans-intro.mp4" class="mc-btn" style="background:var(--pink-deep); color:white;">OnlyFans</a>
            <button class="mc-btn" id="themeToggle" onclick="cycleTheme()" style="background: var(--mc-stone);">
                <i class="fa-solid fa-circle-half-stroke"></i>
            </button>
        </nav>
    </div>
</header>

<style>
    /* Burger Icon Styles */
    .menu-toggle {
        display: flex;
        flex-direction: column;
        justify-content: space-around;
        width: 30px;
        height: 25px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 10;
    }

    .burger-line {
        width: 100%;
        height: 3px;
        background-color: var(--text-main);
        border-radius: 10px;
        transition: all 0.3s linear;
        position: relative;
        transform-origin: 1px;
    }

    /* Animation to "X" when active */
    .menu-toggle.active .burger-line:nth-child(1) {
        transform: rotate(45deg);
    }

    .menu-toggle.active .burger-line:nth-child(2) {
        opacity: 0;
        transform: translateX(20px);
    }

    .menu-toggle.active .burger-line:nth-child(3) {
        transform: rotate(-45deg);
    }

    /* Ensure button only shows on mobile if not already handled in global.css */
    @media (min-width: 769px) {
        .menu-toggle {
            display: none;
        }
    }
</style>

<script is:inline>
    const themes = ['system', 'dark', 'light'];
    const icons = { system: 'fa-circle-half-stroke', dark: 'fa-moon', light: 'fa-sun' };

    function getTheme() {
        return localStorage.getItem('theme') || 'system';
    }

    function applyTheme(theme) {
        document.body.classList.remove('dark-mode', 'light-mode');
        if (theme !== 'system') document.body.classList.add(`${theme}-mode`);
        
        const icon = document.querySelector('#themeToggle i');
        if (icon) icon.className = `fa-solid ${icons[theme]}`;
    }

    function cycleTheme() {
        const current = getTheme();
        const next = themes[(themes.indexOf(current) + 1) % themes.length];
        localStorage.setItem('theme', next);
        applyTheme(next);
    }

    function toggleMenu() {
        // Toggle active class on both the menu and the button for animation
        document.getElementById('navLinks').classList.toggle('active');
        document.getElementById('menuToggle').classList.toggle('active');
    }

    applyTheme(getTheme());
    document.addEventListener("DOMContentLoaded", () => applyTheme(getTheme()));
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
        if (getTheme() === 'system') applyTheme('system');
    });
</script>