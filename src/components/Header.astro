---
import HeaderLink from './HeaderLink.astro';
---
<header>
    <div class="nav-container">
        <div class="logo">Michelle's<span style="color:#fff;"> SHIT AUDIO</span></div>
        
        <button class="menu-toggle" id="menu-toggle-btn">
            [ 🖕🏻 ]
        </button>

        <nav class="nav-links" id="navLinks">
             <HeaderLink href="/" class="mc-btn" style="background:var(--pink-neon); color:white; box-shadow: inset 3px 3px 0 rgba(255,255,255,0.2), inset -3px -3px 0 rgba(0,0,0,0.4), 3px 5px 0 #000, 0 0 15px var(--pink-neon);">Home</HeaderLink>
             <HeaderLink href="/blog" class="mc-btn">Blogs</HeaderLink>
             <HeaderLink href="/about" class="mc-btn">About</HeaderLink>
             <a href="/onlyfans-intro.mp4" class="mc-btn" style="background:var(--pink-deep); color:white;">OnlyFans</a>
        </nav>
    </div>
</header>

<script>
    // Vanilla JS for the menu toggle inside Astro
    document.getElementById('menu-toggle-btn')?.addEventListener('click', () => {
        const nav = document.getElementById('navLinks');
        nav?.classList.toggle('active');
    });
</script>