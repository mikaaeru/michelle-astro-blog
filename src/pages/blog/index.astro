---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

// Fetch all blog posts and sort them by date
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title="Michelle's Playground - Logs" />
	</head>
	<body>
		<Header />
		<main>
			<h1 style="color:var(--pink-neon); border-bottom: 4px solid var(--pink-neon); padding-bottom: 10px; margin-bottom: 30px; text-shadow: 2px 2px 0 #000;">[ LOGS & RAMBLINGS ]</h1>
			
			<div class="blog-grid">
				{posts.length === 0 ? (
					<p style="text-align: center; font-style: italic; color: var(--pink-pastel);">Nothing here yet. The logs are empty.</p>
				) : (
					posts.map((post) => (
						<article class="blog-card">
							<h2>{post.data.title}</h2>
							<span class="card-meta">Date: {post.data.pubDate.toLocaleDateString()} // Tag: {post.data.tags ? post.data.tags.join(', ') : 'None'}</span>
							<p class="card-excerpt">{post.data.description}</p>
							<a href={`/blog/${post.id}/`} class="mc-btn" style="font-size: 1rem; text-align: center;">Read Log</a>
						</article>
					))
				)}
			</div>
		</main>
		<Footer />
		<script is:inline src="/warning.js"></script>
	</body>
</html>