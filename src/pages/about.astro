---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title="Michelle's Playground" />
	</head>
	<body>
		<script is:inline src="/warning.js"></script>
		<Header />
		<main>
			<section class="hero mc-border">
				<img src="/favicon.png" alt="Michelle" class="profile-img">
				<div class="social-links">
					<a href="https://discord.com/users/654535856950083603" target="_blank" class="mc-btn" style="background: #5865F2; color: white;">
						<i class="fa-brands fa-discord"></i> Discord</a>
					<a href="https://github.com/mikaaeru" target="_blank" class="mc-btn" style="background: #333; color: white;">
						<i class="fa-brands fa-github"></i> GitHub</a>
					<a href="https://www.youtube.com/@kamikamieu" target="_blank" class="mc-btn" style="background: #FF0000; color: white;">
						<i class="fa-brands fa-youtube"></i> YouTube</a>
				</div>
				<h1>My name is Michelle</h1>
				<p class="subtitle">Jesus Christ, you came here? Why even bother visiting this site, since there’s practically nothing here. My name is Michelle and I’m not racist because I’m neither white or stereotypically asian. I’m just myself and I don’t care how would anyone perceive me, although I still prefer a small talk about something other than quieting alone.
				</p>
				<div style="margin-top:20px;">
					<span style="font-size:3rem; animation: float 2s infinite;">💖</span>
				</div>
			</section>
			</main>
		<Footer />
	</body>
</html>