---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title="Michelle's Playground" />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro-section" style="text-align:center; padding: 40px 20px; border-bottom: 4px dashed var(--pink-pastel); margin-bottom: 40px;">
				<img src="/background.png" alt="Michelle's Avatar" style="width: 150px; height: 150px; border-radius: 50%; border: 4px solid var(--pink-neon); box-shadow: 0 0 15px var(--pink-neon); margin-bottom: 20px;" />
				<div class="social-links" style="justify-content: center; margin-top: 10px;">
					<a href="https://github.com/mikaaeru" target="_blank" class="mc-btn" style="background: #333; color: white;">
						<i class="fa-brands fa-github"></i> GitHub</a>
					<a href="https://www.youtube.com/@kamikamieu" target="_blank" class="mc-btn" style="background: #FF0000; color: white;">
						<i class="fa-brands fa-youtube"></i> YouTube</a>
				</div>
				<h1>My name is Michelle</h1>
				<p class="subtitle">Jesus Christ, you came here? Why even bother visiting this site, since there’s practically nothing here. My name is Michelle and I’m not racist because I’m neither white or stereotypically asian. I’m just myself and I don’t care how would anyone perceive me, although I still prefer a small talk about something other than quieting alone.</p>
				<div style="margin-top:20px;">
					<span style="font-size:3rem; animation: float 2s infinite;">💖</span>
				</div>
			</section>

			<h2 style="color:var(--pink-pastel); text-shadow: 2px 2px 0 #000;">> Latest Entries_</h2>
			</main>
		<Footer />
		<script is:inline src="/warning.js"></script>
	</body>
</html>